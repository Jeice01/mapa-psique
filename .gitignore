# dependencies
frontend/node_modules/
backend/vendor/

# builds
frontend/dist/
frontend/*.tsbuildinfo

# local env
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local

# logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log
*-server.out.log
*-server.err.log

# backend runtime files
backend/storage/logs/*
backend/storage/temp/*
backend/storage/uploads/*
!backend/storage/logs/.gitkeep
!backend/storage/temp/.gitkeep
!backend/storage/temp/rate-limit/
!backend/storage/temp/rate-limit/.gitkeep
!backend/storage/uploads/.gitkeep

# database dumps and backups
*.sql.gz
*.sql.zip
*.dump
*.dump.sql
*dump*.sql
*backup*.sql
*.bak
*.backup
*.old
*.orig
backups/
backup/
dumps/

