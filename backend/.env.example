APP_ENV=local
APP_URL=http://localhost:8080
APP_ALLOWED_ORIGINS=http://localhost:5173,https://mapapsique.orbisconect.com

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# Hostinger-style aliases are also supported:
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASS=your_database_password

SESSION_COOKIE_NAME=mapa_psique_session
SESSION_LIFETIME_MINUTES=120
CSRF_ENABLED=true

MAIL_FROM=no-reply@mapapsique.orbisconect.com
MAIL_FROM_NAME=Mapa da Psique

# ── AI providers ─────────────────────────────────────────────────────────────
# At least one key must be set to enable AI analysis.
# OpenAI is primary (text + DALL-E image). Anthropic is text-only fallback.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-opus-4-8
